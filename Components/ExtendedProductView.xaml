<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartFridgeTracker.Components.ExtendedProductView">
    <Grid
        Padding="10"
        ColumnDefinitions="Auto,*,Auto,60,60"
        VerticalOptions="Center">
               

        <!-- Emoji -->
        <Border Grid.Column="0" 
             Style="{StaticResource EmojiBorderStyle}" 
             Stroke="{Binding StatusColor}">
            <Label Text="{Binding Emoji}" Style="{StaticResource EmojiLabelStyle}" />
        </Border>

        <!--  Name  -->
        <Label
            Grid.Column="1"
            Style="{StaticResource ProductNameStyle}"
            Text="{Binding Name}" />    

        <!--  Count & Quantity  -->
        <VerticalStackLayout Grid.Column="2" 
                     HorizontalOptions="End">

            <Label Text="{Binding Count}" 
           FontSize="22" 
           FontAttributes="Bold" 
           Style="{StaticResource LabelPropertyStyle}"
           HorizontalOptions="Center"/>

            <Label Text="{Binding Quantity}" 
           Style="{StaticResource LabelCharacteristicStyle}"
           HorizontalOptions="Center"/>
        </VerticalStackLayout>
       
    </Grid>
</ContentView>
