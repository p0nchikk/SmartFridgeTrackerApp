<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartFridgeTracker.Components.InventoryProductView">
    <Grid ColumnDefinitions="Auto, *, 100" ColumnSpacing="15" Padding="15, 8">
        <!-- Emoji -->
        <Border Grid.Column="0" 
            Style="{StaticResource EmojiBorderStyle}" 
            Stroke="{Binding StatusColor}">
            <Label Text="{Binding Emoji}" Style="{StaticResource EmojiLabelStyle}" />
        </Border>

        <!-- Name -->
        <Label Grid.Column="1" 
           Text="{Binding Name}" 
           Style="{StaticResource ProductNameStyle}" />

        <!--  Quantity as a Progress Bar -->
        <Frame
                Grid.Column="2"
                BorderColor="{StaticResource Gray600}"
                CornerRadius="8"
                Padding="0"
                HeightRequest="30"
                WidthRequest="120"
                HasShadow="False"
                IsClippedToBounds="True"
                VerticalOptions="Center"
                HorizontalOptions="End">
            <ProgressBar 
                 Progress="{Binding FillRatio}"
                 ProgressColor="{Binding ProgressColor}" 
                 BackgroundColor="#E0E0E0"
                 VerticalOptions="Center"
                 ScaleY="10"/>
        </Frame>
    </Grid>
</ContentView>
