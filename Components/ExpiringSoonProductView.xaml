<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartFridgeTracker.Components.ExpiringSoonProductView">
    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" Padding="15, 8">
        <!-- Emoji -->
        <Border Grid.Column="0" 
                Style="{StaticResource EmojiBorderStyle}" 
                Stroke="{Binding StatusColor}">
            <Label Text="{Binding Emoji}" Style="{StaticResource EmojiLabelStyle}" />
        </Border>

        <!-- Name -->
        <Label Grid.Column="1" 
               Text="{Binding Name}" 
               Style="{StaticResource ProductNameStyle}" />

        <!-- Life Days -->
        <VerticalStackLayout Grid.Column="2" 
                             HorizontalOptions="End">

            <Label Text="{Binding LifeDays}" 
                   FontSize="22" 
                   FontAttributes="Bold" 
                   Style="{StaticResource LabelPropertyStyle}"
                   HorizontalOptions="Center"/>

            <Label Text="days" 
                   Style="{StaticResource LabelCharacteristicStyle}"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

    </Grid>
</ContentView>
