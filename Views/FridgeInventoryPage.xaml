<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SmartFridgeTracker.ViewModels"
             x:Class="SmartFridgeTracker.Views.FridgeInventoryPage">

    <!--  Container Grid  -->
    <Grid Style="{StaticResource ThreeRowGridContainerStyle}">
        <VerticalStackLayout Grid.Row="0">
            <!-- Header -->
            <Label
             Grid.Column="1"
             HorizontalOptions="Center"
             Style="{StaticResource HeaderLabelStyle}"
             Text="My Fridge" />

            <!-- Divider -->
            <BoxView Style="{StaticResource HorizontalLineStyle}" />
        </VerticalStackLayout>

        <!--  Product List  -->
         <CollectionView
         Grid.Row="1"
         Margin="0,10,0,10"
         ItemsSource="{Binding Products}">
            <!--  EMPTY LIST  -->
            <CollectionView.EmptyView>
                <VerticalStackLayout>
                    <Label
                 FontSize="20"
                 HorizontalOptions="Center"
                 Text="You have no products yet"
                 TextColor="{StaticResource Gray600}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <!--  FILLED LIST  -->
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItem
                         BackgroundColor="{StaticResource RedBright}"
                        Command="{Binding RemoveItemCommand, Source={x:RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}}"   
                         CommandParameter="{Binding .}"
                         Text="Remove" />
                        </SwipeView.RightItems>

                        <Grid
                     Padding="10"
                     ColumnDefinitions="Auto,*,Auto,60"
                     VerticalOptions="Center">
                            <!--  Remove  -->
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OnProductTappedCommand, Source={x:RelativeSource AncestorType={x:Type viewmodels:FridgeInventoryViewModel}}}" 
                                               CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>

                            <!-- Emoji -->
                            <Border Grid.Column="0" 
                                 Style="{StaticResource EmojiBorderStyle}" 
                                 Stroke="{Binding StatusColor}">
                                <Label Text="{Binding Emoji}" Style="{StaticResource EmojiLabelStyle}" />
                            </Border>

                            <!--  Name  -->
                            <Label
                                 Grid.Column="1"
                                 Style="{StaticResource ProductNameStyle}"
                                 Text="{Binding Name}" />

                            <!--  Count & Quantity  -->
                            <VerticalStackLayout Grid.Column="2" 
                                 HorizontalOptions="End">

                                <Label Text="{Binding Count}" 
                                   FontSize="22" 
                                   FontAttributes="Bold" 
                                   Style="{StaticResource LabelPropertyStyle}"
                                   HorizontalOptions="Center"/>

                                <Label Text="{Binding Quantity}" 
                                   Style="{StaticResource LabelCharacteristicStyle}"
                                   HorizontalOptions="Center"/> 
                            </VerticalStackLayout>

                            <!--  Decrement Count  -->
                            <Button
                         Grid.Column="3"
                         Command="{Binding DecrementCountOfItemCommand, Source={x:RelativeSource AncestorType={x:Type viewmodels:FridgeInventoryViewModel}, Mode=FindAncestorBindingContext}}"
                         CommandParameter="{Binding .}"
                         Text="-" />
                        </Grid>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
    </Grid>
</ContentPage>