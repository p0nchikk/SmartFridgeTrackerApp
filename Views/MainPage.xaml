<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SmartFridgeTracker.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:SmartFridgeTracker.ViewModels">

    <!--  Container Grid  -->
    <Grid Style="{StaticResource ThreeRowGridContainerStyle}">

        <!--  Navbar  -->
        <VerticalStackLayout Grid.Row="0">
            <Grid Style="{StaticResource ThreeColumnGridContainerStyle}">
                <!--  Profile Button  -->
                <ImageButton
                    Command="{Binding ProfileImageTappedCommand}"
                    Source="profile_placeholder.png"
                    Style="{StaticResource ImageButtonStyle}" />
                <!-- Header -->
                <Label
                    Grid.Column="1"
                    HorizontalOptions="Center"
                    Style="{StaticResource HeaderLabelStyle}"
                    Text="Main" />
                <!-- Menu Button -->
                <ImageButton
                     Grid.Column="2"
                     Command="{Binding OpenMenuCommand}"
                     Source="menu.png"
                     Style="{StaticResource ImageButtonStyle}" />
            </Grid>

            <!-- Divider -->
            <BoxView Style="{StaticResource HorizontalLineStyle}" />

        </VerticalStackLayout>

        <ScrollView   Grid.Row="1">
       
        <!--  Dashboard  -->
            <Grid          
                RowDefinitions="*,*,*,*"
                RowSpacing="15">
                
                <!--  Sector #1 - Fridge Summary -->
                <Frame
                Grid.Row="0"
                BackgroundColor="{StaticResource BackgroundLight}"
                CornerRadius="20"
                Style="{StaticResource SectorFrameStyle}"
                HeightRequest="170">
                    <VerticalStackLayout>
                        <!-- Greeting  -->
                        <Label
                         Text="{Binding Greeting}"
                         Style="{StaticResource RegularLabelStyle}" />
                        <Label
                         Text="your fridge have"
                         Style="{StaticResource SubheaderLabelStyle}" />
                    </VerticalStackLayout>
                </Frame>
                
                <!--  Sector #2 - Eat Soon -->
                <Frame
                Grid.Row="1"
                BackgroundColor="{StaticResource BackgroundLight}"
                CornerRadius="20"
                Style="{StaticResource SectorFrameStyle}"
                HeightRequest="170">
                    <VerticalStackLayout>
                        <!-- Header  -->
                        <Label
                         Text="Eat soon"
                         Style="{StaticResource RegularLabelStyle}" />
                    </VerticalStackLayout>
                </Frame>
                
                <!--  Sector #3 - All Products -->
                <Frame
                Grid.Row="2"
                BackgroundColor="{StaticResource BackgroundLight}"
                CornerRadius="20"
                Style="{StaticResource SectorFrameStyle}"
                HeightRequest="170">
                    <VerticalStackLayout>
                        <!-- Header  -->
                        <Label
                         Text="All Products"
                         Style="{StaticResource RegularLabelStyle}" />
                    </VerticalStackLayout>
                </Frame>
                
                <!--  Sector #4 - Receipts -->
                <Frame
                Grid.Row="3"
                BackgroundColor="{StaticResource BackgroundLight}"
                CornerRadius="20"
                Style="{StaticResource SectorFrameStyle}"
                HeightRequest="170">
                    <VerticalStackLayout>
                        <!-- Header  -->
                        <Label
                         Text="You can cook:"
                         Style="{StaticResource RegularLabelStyle}" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </ScrollView>


        <!--  Button ADD  -->
        <Button
            Grid.Row="2"
            BackgroundColor="{StaticResource PrimaryDark}"
            Style="{StaticResource ButtonStyle}"
            HeightRequest="70"
            WidthRequest="70"
            HorizontalOptions="End"
            CornerRadius="50"
            Command="{Binding GoToAddProductPageCommand}"
            Text="+" />

    </Grid>
</ContentPage>