<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SmartFridgeTracker.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:comp="clr-namespace:SmartFridgeTracker.Components"
    xmlns:viewmodels="clr-namespace:SmartFridgeTracker.ViewModels">

    <!--  Container Grid  -->
    <Grid Style="{StaticResource ThreeRowGridContainerStyle}">

        <!--  Navbar  -->
        <VerticalStackLayout Grid.Row="0">
            <Grid Style="{StaticResource ThreeColumnGridContainerStyle}">
                <!--  Profile Button  -->
                <ImageButton
                    Command="{Binding ProfileImageTappedCommand}"
                    Source="profile_placeholder.png"
                    Style="{StaticResource ImageButtonStyle}" />
                <!-- Header -->
                <Label
                    Grid.Column="1"
                    HorizontalOptions="Center"
                    Style="{StaticResource HeaderLabelStyle}"
                    Text="Main" />
                <!-- Menu Button -->
                <ImageButton
                     Grid.Column="2"
                     Command="{Binding OpenMenuCommand}"
                     Source="menu.png"
                     Style="{StaticResource ImageButtonStyle}" />
            </Grid>

            <!-- Divider -->
            <BoxView Style="{StaticResource HorizontalLineStyle}" />

        </VerticalStackLayout>

        <ScrollView   Grid.Row="1">
       
        <!--  Dashboard  -->
            <Grid          
                RowDefinitions="*,*,*,*"
                RowSpacing="15">
                
                <!--  Sector #1 - Fridge Summary -->
                <Frame
                Grid.Row="0"
                BackgroundColor="{StaticResource BackgroundLight}"
                CornerRadius="20"
                Style="{StaticResource SectorFrameStyle}"
                HeightRequest="210">
                    <VerticalStackLayout Spacing="5">
                        <!-- Greeting  -->
                        <Label
                         Text="{Binding Greeting}"
                         Style="{StaticResource RegularLabelStyle}" />
                        <Label
                         Text="your fridge have"
                         Style="{StaticResource SubheaderLabelStyle}" />

                        <Grid RowDefinitions="Auto,Auto" 
                              ColumnDefinitions="*,*,*" 
                              RowSpacing="5"
                              HorizontalOptions="FillAndExpand"
                              Padding="0,10,0,0">
                            <!-- Expiring soon count -->
                            <Border
                                Style="{StaticResource EmojiBorderStyle}"
                                Stroke="{StaticResource SecondaryBright}"
                                HorizontalOptions="Center">
                                <Label Style="{StaticResource EmojiLabelStyle}"
                                       TextColor="{StaticResource Gray600}"
                                       Text="{Binding ExpiringSoonCount}"/>
                            </Border>
                            <Label Grid.Row="1"
                                 Style="{StaticResource LabelCharacteristicStyle}"
                                 HorizontalTextAlignment="Center"
                                 HorizontalOptions="Center"
                                 Text="expiring soon"/>
                            
                            <!-- Total count -->
                            <Border Grid.Column="1"
                                Style="{StaticResource EmojiBorderStyle}"
                                Stroke="{StaticResource PrimaryBright}"
                                HorizontalOptions="Center">
                                <Label Style="{StaticResource EmojiLabelStyle}"
                                       TextColor="{StaticResource Gray600}"
                                       Text="{Binding TotalCount}"/>
                            </Border>
                            <Label Grid.Row="1" Grid.Column="1"
                                Style="{StaticResource LabelCharacteristicStyle}"
                                 HorizontalTextAlignment="Center"
                                 HorizontalOptions="Center"
                                Text="total"/>
                            
                            <!-- Expired count -->
                            <Border Grid.Column="2" 
                                Style="{StaticResource EmojiBorderStyle}"
                                Stroke="{StaticResource RedBright}"
                                HorizontalOptions="Center">
                                <Label Style="{StaticResource EmojiLabelStyle}"
                                       TextColor="{StaticResource Gray600}"
                                       Text="{Binding ExpiredCount}"/>
                            </Border>
                            <Label Grid.Row="1" Grid.Column="2"
                                Style="{StaticResource LabelCharacteristicStyle}"
                                HorizontalTextAlignment="Center"
                                HorizontalOptions="Center"
                                Text="expired"/>
                            
                        </Grid>
                        
                    </VerticalStackLayout>
                </Frame>
                
                <!--  Sector #2 - Eat Soon -->
                <Frame
                Grid.Row="1"
                BackgroundColor="{StaticResource BackgroundLight}"
                CornerRadius="20"
                Style="{StaticResource SectorFrameStyle}"
                MinimumHeightRequest="200"
                MaximumHeightRequest="310">
                    <Grid RowDefinitions="Auto, *, Auto">
                        <!-- Header  -->
                        <Label
                         Text="Eat soon"
                         Style="{StaticResource RegularLabelStyle}" />

                        <!-- Expiring Soon Products -->
                        <CollectionView
                             Grid.Row="1"
                             Margin="0,10,0,10"
                             ItemsSource="{Binding ExpiringSoonProducts}">
                            
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <comp:ExpiringSoonProductView />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Navigation -->
                        <ImageButton Grid.Row="2"
                              Source="right_arrow.png"
                              HorizontalOptions="End"
                              Style="{StaticResource ImageButtonStyle}"
                              Command="{Binding GoToExpiringSoonProducts}"/>

                    </Grid>
                </Frame>
                
                <!--  Sector #3 - All Products -->
                <Frame
                Grid.Row="2"
                BackgroundColor="{StaticResource BackgroundLight}"
                CornerRadius="20"
                Style="{StaticResource SectorFrameStyle}"
                MinimumHeightRequest="200"
                MaximumHeightRequest="310">
                    <Grid RowDefinitions="Auto, *, Auto">
                        <!-- Header  -->
                        <Label
                         Text="All Products"
                         Style="{StaticResource RegularLabelStyle}" />

                        <!-- All Products -->
                        <CollectionView
                                 Grid.Row="1"
                                 Margin="0,10,0,10"
                                 ItemsSource="{Binding Products}">
                            
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="2" />
                            </CollectionView.ItemsLayout>
                            
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <comp:InventoryProductView />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                            <CollectionView.EmptyView>
                                <Label Text="No products found" Style="{StaticResource SubheaderLabelStyle}" />
                            </CollectionView.EmptyView>

                        </CollectionView>
                        
                        <!-- Navigation -->
                        <ImageButton Grid.Row="2"
                                     Source="right_arrow.png"
                                     HorizontalOptions="End"
                                     Style="{StaticResource ImageButtonStyle}"
                                     Command="{Binding GoToFridgeInventoryCommand}"/>
                    </Grid>
                </Frame>
                
                <!--  Sector #4 - Receipts -->
                <Frame
                Grid.Row="3"
                BackgroundColor="{StaticResource BackgroundLight}"
                CornerRadius="20"
                Style="{StaticResource SectorFrameStyle}"
                HeightRequest="170">
                    <VerticalStackLayout>
                        <!-- Header  -->
                        <Label
                         Text="You can cook:"
                         Style="{StaticResource RegularLabelStyle}" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </ScrollView>


        <!--  Button ADD  -->
        <Button
            Grid.Row="2"
            BackgroundColor="{StaticResource PrimaryDark}"
            Style="{StaticResource ButtonStyle}"
            HeightRequest="70"
            WidthRequest="70"
            HorizontalOptions="End"
            CornerRadius="50"
            Command="{Binding GoToAddProductPageCommand}"
            Text="+" />

    </Grid>
</ContentPage>